# RAG System Configuration
# Copy this to .env and adjust values

# Qdrant local storage path
QDRANT_PATH=./data/qdrant_db
QDRANT_COLLECTION=rag_documents

# Embedding model (local HuggingFace)
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_BATCH_SIZE=8

# Reranker model (local HuggingFace)
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Ollama LLM settings
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=120

# Retrieval settings
RETRIEVAL_TOP_K=20
RERANK_TOP_N=5
CHUNK_SIZE=300
CHUNK_OVERLAP=50
USE_HYDE=true

# Flask settings
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/rag.log
